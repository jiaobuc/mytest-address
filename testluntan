<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>回声论坛 — Echo Forum</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@400;600;700&family=Source+Serif+4:ital,wght@0,400;0,600;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --bg: #0f0e0c;
      --bg-raised: #1a1815;
      --bg-surface: #222019;
      --bg-hover: #2c2a22;
      --border: #3a3628;
      --border-light: #4a4535;
      --accent: #d4a634;
      --accent-dim: #b8912d;
      --accent-glow: rgba(212, 166, 52, 0.15);
      --text-primary: #f0ebe0;
      --text-body: #c8c0b0;
      --text-muted: #7a7265;
      --text-faint: #554f45;
      --green: #5cb87a;
      --red: #c95d5d;
      --blue: #5d8ec9;
      --purple: #9b7ec9;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'Source Serif 4', 'Noto Serif SC', Georgia, serif;
      background: var(--bg);
      color: var(--text-body);
      line-height: 1.7;
      min-height: 100vh;
      position: relative;
    }

    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='1'/%3E%3C/svg%3E");
      opacity: 0.03;
      pointer-events: none;
      z-index: 9999;
    }

    a { color: var(--accent); text-decoration: none; transition: color 0.2s; }
    a:hover { color: var(--text-primary); }

    /* ─── Header ─── */
    .site-header {
      background: linear-gradient(180deg, #1a1815 0%, var(--bg) 100%);
      border-bottom: 1px solid var(--border);
      padding: 0;
      position: sticky;
      top: 0;
      z-index: 100;
    }

    .header-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      max-width: 1200px;
      margin: 0 auto;
      padding: 16px 24px;
    }

    .logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 28px;
      font-weight: 700;
      color: var(--accent);
      letter-spacing: 0.02em;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .logo-icon {
      width: 32px;
      height: 32px;
      border: 2px solid var(--accent);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 14px;
      color: var(--accent);
      font-family: 'DM Mono', monospace;
    }

    .header-actions {
      display: flex;
      align-items: center;
      gap: 12px;
    }

    .search-box {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 8px 14px;
      color: var(--text-body);
      font-family: inherit;
      font-size: 14px;
      width: 220px;
      transition: border-color 0.2s, box-shadow 0.2s;
      outline: none;
    }

    .search-box:focus {
      border-color: var(--accent-dim);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }

    .search-box::placeholder { color: var(--text-faint); }

    .btn {
      font-family: 'DM Mono', monospace;
      font-size: 13px;
      padding: 8px 18px;
      border-radius: 6px;
      border: 1px solid var(--border);
      background: var(--bg-surface);
      color: var(--text-body);
      cursor: pointer;
      transition: all 0.2s;
      letter-spacing: 0.03em;
    }

    .btn:hover {
      border-color: var(--accent-dim);
      color: var(--text-primary);
      background: var(--bg-hover);
    }

    .btn-primary {
      background: var(--accent);
      color: var(--bg);
      border-color: var(--accent);
      font-weight: 500;
    }

    .btn-primary:hover {
      background: var(--accent-dim);
      border-color: var(--accent-dim);
      color: var(--bg);
    }

    /* ─── Nav ─── */
    .nav-bar {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
      display: flex;
      gap: 4px;
      border-top: 1px solid var(--border);
    }

    .nav-link {
      padding: 10px 16px;
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      color: var(--text-muted);
      text-transform: uppercase;
      letter-spacing: 0.08em;
      border-bottom: 2px solid transparent;
      transition: all 0.2s;
      cursor: pointer;
    }

    .nav-link:hover { color: var(--text-primary); }
    .nav-link.active {
      color: var(--accent);
      border-bottom-color: var(--accent);
    }

    /* ─── Layout ─── */
    .main-wrap {
      max-width: 1200px;
      margin: 0 auto;
      padding: 28px 24px 60px;
      display: grid;
      grid-template-columns: 1fr 300px;
      gap: 28px;
    }

    /* ─── Breadcrumb ─── */
    .breadcrumb {
      font-family: 'DM Mono', monospace;
      font-size: 12px;
      color: var(--text-faint);
      margin-bottom: 20px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .breadcrumb span { color: var(--text-muted); }

    /* ─── Section Titles ─── */
    .section-header {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 16px;
      padding-bottom: 12px;
      border-bottom: 1px solid var(--border);
    }

    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 22px;
      font-weight: 600;
      color: var(--text-primary);
      letter-spacing: 0.01em;
    }

    .section-badge {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      background: var(--bg-surface);
      border: 1px solid var(--border);
      color: var(--text-muted);
      padding: 3px 10px;
      border-radius: 20px;
    }

    /* ─── Category Cards ─── */
    .categories-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
      margin-bottom: 32px;
    }

    .category-card {
      background: var(--bg-raised);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 18px 20px;
      cursor: pointer;
      transition: all 0.25s ease;
      position: relative;
      overflow: hidden;
    }

    .category-card::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      width: 3px;
      height: 100%;
      background: var(--cat-color, var(--accent));
      opacity: 0.6;
      transition: opacity 0.25s;
    }

    .category-card:hover {
      border-color: var(--border-light);
      background: var(--bg-surface);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(0,0,0,0.3);
    }

    .category-card:hover::before { opacity: 1; }

    .cat-icon {
      font-size: 20px;
      margin-bottom: 8px;
      display: block;
    }

    .cat-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 17px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 4px;
    }

    .cat-desc {
      font-size: 13px;
      color: var(--text-muted);
      line-height: 1.5;
    }

    .cat-stats {
      display: flex;
      gap: 16px;
      margin-top: 10px;
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      color: var(--text-faint);
    }

    /* ─── Thread List ─── */
    .thread-list {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .thread-item {
      display: grid;
      grid-template-columns: 44px 1fr auto;
      gap: 14px;
      align-items: center;
      padding: 14px 16px;
      background: var(--bg-raised);
      border: 1px solid var(--border);
      border-radius: 6px;
      cursor: pointer;
      transition: all 0.2s;
      animation: fadeUp 0.4s ease forwards;
      opacity: 0;
    }

    .thread-item:nth-child(1) { animation-delay: 0.05s; }
    .thread-item:nth-child(2) { animation-delay: 0.1s; }
    .thread-item:nth-child(3) { animation-delay: 0.15s; }
    .thread-item:nth-child(4) { animation-delay: 0.2s; }
    .thread-item:nth-child(5) { animation-delay: 0.25s; }
    .thread-item:nth-child(6) { animation-delay: 0.3s; }
    .thread-item:nth-child(7) { animation-delay: 0.35s; }
    .thread-item:nth-child(8) { animation-delay: 0.4s; }

    .thread-item:hover {
      border-color: var(--border-light);
      background: var(--bg-surface);
    }

    .thread-item.pinned {
      border-left: 2px solid var(--accent);
    }

    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(12px); }
      to { opacity: 1; transform: translateY(0); }
    }

    .thread-avatar {
      width: 44px;
      height: 44px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Cormorant Garamond', serif;
      font-weight: 700;
      font-size: 18px;
      color: var(--bg);
      flex-shrink: 0;
    }

    .thread-body { min-width: 0; }

    .thread-tags {
      display: flex;
      gap: 6px;
      margin-bottom: 4px;
      flex-wrap: wrap;
    }

    .tag {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      padding: 2px 8px;
      border-radius: 3px;
      background: var(--accent-glow);
      color: var(--accent);
      border: 1px solid rgba(212, 166, 52, 0.2);
    }

    .tag.hot {
      background: rgba(201, 93, 93, 0.12);
      color: var(--red);
      border-color: rgba(201, 93, 93, 0.2);
    }

    .tag.new {
      background: rgba(92, 184, 122, 0.12);
      color: var(--green);
      border-color: rgba(92, 184, 122, 0.2);
    }

    .tag.pin {
      background: rgba(93, 142, 201, 0.12);
      color: var(--blue);
      border-color: rgba(93, 142, 201, 0.2);
    }

    .thread-title {
      font-size: 15px;
      color: var(--text-primary);
      font-weight: 600;
      margin-bottom: 3px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      transition: color 0.2s;
    }

    .thread-item:hover .thread-title { color: var(--accent); }

    .thread-meta {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      color: var(--text-faint);
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .thread-meta .author { color: var(--text-muted); }

    .thread-stats-col {
      display: flex;
      flex-direction: column;
      align-items: flex-end;
      gap: 4px;
      flex-shrink: 0;
    }

    .reply-count {
      font-family: 'DM Mono', monospace;
      font-size: 13px;
      font-weight: 500;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      gap: 4px;
    }

    .reply-count .num { color: var(--text-primary); }

    .last-reply {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      color: var(--text-faint);
    }

    /* ─── Sidebar ─── */
    .sidebar { display: flex; flex-direction: column; gap: 20px; }

    .sidebar-card {
      background: var(--bg-raised);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 18px 20px;
    }

    .sidebar-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 16px;
      font-weight: 600;
      color: var(--text-primary);
      margin-bottom: 14px;
      padding-bottom: 10px;
      border-bottom: 1px solid var(--border);
    }

    .stat-row {
      display: flex;
      justify-content: space-between;
      padding: 6px 0;
      font-size: 13px;
    }

    .stat-label { color: var(--text-muted); }
    .stat-value {
      font-family: 'DM Mono', monospace;
      color: var(--text-primary);
      font-weight: 500;
    }

    .online-dot {
      width: 7px;
      height: 7px;
      border-radius: 50%;
      background: var(--green);
      display: inline-block;
      margin-right: 6px;
      animation: pulse 2s infinite;
    }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    /* ─── User List ─── */
    .user-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }

    .user-row {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 6px 0;
    }

    .user-mini-avatar {
      width: 32px;
      height: 32px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Cormorant Garamond', serif;
      font-weight: 700;
      font-size: 13px;
      color: var(--bg);
      flex-shrink: 0;
    }

    .user-info { min-width: 0; }

    .user-name {
      font-size: 13px;
      color: var(--text-primary);
      font-weight: 600;
    }

    .user-role {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      color: var(--text-faint);
    }

    /* ─── Trending ─── */
    .trending-item {
      padding: 8px 0;
      border-bottom: 1px solid var(--border);
      cursor: pointer;
      transition: all 0.2s;
    }

    .trending-item:last-child { border-bottom: none; }

    .trending-item:hover .trending-title { color: var(--accent); }

    .trending-num {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      color: var(--accent);
      margin-bottom: 2px;
    }

    .trending-title {
      font-size: 13px;
      color: var(--text-body);
      font-weight: 600;
      transition: color 0.2s;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }

    .trending-meta {
      font-family: 'DM Mono', monospace;
      font-size: 10px;
      color: var(--text-faint);
      margin-top: 2px;
    }

    /* ─── Thread Detail Modal ─── */
    .modal-overlay {
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.7);
      backdrop-filter: blur(4px);
      z-index: 200;
      display: none;
      align-items: flex-start;
      justify-content: center;
      padding: 40px 20px;
      overflow-y: auto;
    }

    .modal-overlay.open { display: flex; }

    .modal-content {
      background: var(--bg-raised);
      border: 1px solid var(--border);
      border-radius: 10px;
      width: 100%;
      max-width: 740px;
      animation: modalIn 0.3s ease;
    }

    @keyframes modalIn {
      from { opacity: 0; transform: translateY(20px) scale(0.98); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    .modal-header {
      padding: 24px 28px 18px;
      border-bottom: 1px solid var(--border);
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
    }

    .modal-close {
      background: none;
      border: none;
      color: var(--text-muted);
      font-size: 22px;
      cursor: pointer;
      padding: 4px 8px;
      border-radius: 4px;
      transition: all 0.2s;
      line-height: 1;
    }

    .modal-close:hover {
      background: var(--bg-surface);
      color: var(--text-primary);
    }

    .modal-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 24px;
      font-weight: 700;
      color: var(--text-primary);
      line-height: 1.3;
    }

    .modal-body { padding: 24px 28px; }

    .post {
      display: flex;
      gap: 14px;
      padding: 16px 0;
      border-bottom: 1px solid var(--border);
    }

    .post:last-child { border-bottom: none; }

    .post-avatar {
      width: 40px;
      height: 40px;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-family: 'Cormorant Garamond', serif;
      font-weight: 700;
      font-size: 16px;
      color: var(--bg);
      flex-shrink: 0;
    }

    .post-content { flex: 1; min-width: 0; }

    .post-header {
      display: flex;
      align-items: center;
      gap: 10px;
      margin-bottom: 8px;
    }

    .post-author {
      font-size: 14px;
      font-weight: 600;
      color: var(--text-primary);
    }

    .post-time {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      color: var(--text-faint);
    }

    .post-text {
      font-size: 14px;
      line-height: 1.75;
      color: var(--text-body);
    }

    .post-actions {
      display: flex;
      gap: 14px;
      margin-top: 10px;
    }

    .post-action {
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      color: var(--text-faint);
      cursor: pointer;
      transition: color 0.2s;
      background: none;
      border: none;
      padding: 0;
    }

    .post-action:hover { color: var(--accent); }

    /* ─── Reply Box ─── */
    .reply-box {
      padding: 20px 28px;
      border-top: 1px solid var(--border);
    }

    .reply-textarea {
      width: 100%;
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 14px;
      color: var(--text-body);
      font-family: inherit;
      font-size: 14px;
      resize: vertical;
      min-height: 90px;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
      line-height: 1.6;
    }

    .reply-textarea:focus {
      border-color: var(--accent-dim);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }

    .reply-textarea::placeholder { color: var(--text-faint); }

    .reply-actions {
      display: flex;
      justify-content: flex-end;
      margin-top: 10px;
      gap: 8px;
    }

    /* ─── New Thread Modal ─── */
    .new-thread-modal .modal-body {
      display: flex;
      flex-direction: column;
      gap: 14px;
    }

    .form-input {
      width: 100%;
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 10px 14px;
      color: var(--text-body);
      font-family: inherit;
      font-size: 14px;
      outline: none;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-input:focus {
      border-color: var(--accent-dim);
      box-shadow: 0 0 0 3px var(--accent-glow);
    }

    .form-input::placeholder { color: var(--text-faint); }

    .form-select {
      background: var(--bg-surface);
      border: 1px solid var(--border);
      border-radius: 6px;
      padding: 10px 14px;
      color: var(--text-body);
      font-family: inherit;
      font-size: 14px;
      outline: none;
      appearance: none;
      cursor: pointer;
    }

    /* ─── Footer ─── */
    .site-footer {
      max-width: 1200px;
      margin: 0 auto;
      padding: 24px;
      border-top: 1px solid var(--border);
      text-align: center;
      font-family: 'DM Mono', monospace;
      font-size: 11px;
      color: var(--text-faint);
    }

    /* ─── Responsive ─── */
    @media (max-width: 900px) {
      .main-wrap {
        grid-template-columns: 1fr;
      }
      .categories-grid {
        grid-template-columns: 1fr;
      }
      .sidebar { order: -1; }
    }

    @media (max-width: 600px) {
      .header-top { flex-wrap: wrap; gap: 12px; }
      .search-box { width: 100%; order: 3; }
      .thread-item { grid-template-columns: 36px 1fr; }
      .thread-stats-col { display: none; }
      .nav-bar { overflow-x: auto; }
    }

    /* ─── Scrollbar ─── */
    ::-webkit-scrollbar { width: 8px; }
    ::-webkit-scrollbar-track { background: var(--bg); }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
    ::-webkit-scrollbar-thumb:hover { background: var(--border-light); }

    /* ─── Utility ─── */
    .sr-only {
      position: absolute;
      width: 1px; height: 1px;
      padding: 0; margin: -1px;
      overflow: hidden;
      clip: rect(0,0,0,0);
      border: 0;
    }
  </style>
</head>
<body>

  <!-- Header -->
  <header class="site-header">
    <div class="header-top">
      <div class="logo">
        <div class="logo-icon">E</div>
        回声论坛
      </div>
      <div class="header-actions">
        <input type="text" class="search-box" placeholder="搜索帖子、用户、话题…" aria-label="搜索">
        <button class="btn" id="loginBtn">登录</button>
        <button class="btn btn-primary" id="newThreadBtn">发布新帖</button>
      </div>
    </div>
    <nav class="nav-bar" role="navigation">
      <span class="nav-link active" data-view="home">首页</span>
      <span class="nav-link" data-view="latest">最新</span>
      <span class="nav-link" data-view="hot">热门</span>
      <span class="nav-link" data-view="unanswered">未回复</span>
    </nav>
  </header>

  <!-- Main Content -->
  <main class="main-wrap">
    <div class="content-area">

      <!-- Breadcrumb -->
      <div class="breadcrumb">
        首页 <span>›</span> 所有版块
      </div>

      <!-- Categories -->
      <section>
        <div class="section-header">
          <h2 class="section-title">版块分类</h2>
          <span class="section-badge">6 个版块</span>
        </div>
        <div class="categories-grid">
