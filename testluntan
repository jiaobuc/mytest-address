        <!-- Posts populated by JS -->
      </div>
      <div class="reply-box">
        <textarea class="reply-textarea" placeholder="写下你的回复…" id="replyInput"></textarea>
        <div class="reply-actions">
          <button class="btn" onclick="document.getElementById('threadModal').classList.remove('open')">取消</button>
          <button class="btn btn-primary" id="submitReply">发布回复</button>
        </div>
