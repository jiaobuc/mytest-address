  <!-- New Thread Modal -->
  <div class="modal-overlay new-thread-modal" id="newThreadModal">
    <div class="modal-content">
      <div class="modal-header">
        <h3 class="modal-title">发布新帖</h3>
        <button class="modal-close" onclick="document.getElementById('newThreadModal').classList.remove('open')">&times;</button>
      </div>
      <div class="modal-body">
        <input type="text" class="form-input" placeholder="帖子标题" id="newTitle">
        <select class="form-input form-select" id="newCategory">
          <option value="">选择版块…</option>
          <option value="tech">技术讨论</option>
          <option value="design">设计创意</option>
          <option value="life">生活杂谈</option>
          <option value="creative">创作分享</option>
          <option value="reading">读书会</option>
          <option value="feedback">站务建议</option>
        </select>
        <textarea class="reply-textarea" placeholder="帖子内容…" id="newContent" style="min-height:160px"></textarea>
        <div class="reply-actions">
          <button class="btn" onclick="document.getElementById('newThreadModal').classList.remove('open')">取消</button>
          <button class="btn btn-primary" id="submitThread">发布</button>
        </div>
      </div>
    </div>
  </div>

  <footer class="site-footer">
    回声论坛 Echo Forum &copy; 2026 &mdash; 测试环境 &mdash; 数据仅供演示
  </footer>

<script>
  // ─── Mock Data ───
  const avatarColors = ['#d4a634','#5cb87a','#5d8ec9','#c95d5d','#9b7ec9','#7ac9a8','#c9895d','#5dc9b8'];

  const threads = [
    { id:1, title:'2026 年最值得学习的编程语言是什么？', author:'深海鱼', avatar:'深', color:'#5d8ec9', cat:'tech', tags:['hot'], replies:128, views:3420, time:'10 分钟前', pinned:true },
    { id:2, title:'用 Rust 重写了一个 CLI 工具，性能提升 40 倍', author:'铁锈猎人', avatar:'铁', color:'#c95d5d', cat:'tech', tags:['new'], replies:67, views:1893, time:'32 分钟前', pinned:false },
    { id:3, title:'分享我的极简主义工作台布置', author:'木白', avatar:'木', color:'#7ac9a8', cat:'life', tags:[], replies:43, views:876, time:'1 小时前', pinned:false },
    { id:4, title:'如何让配色方案更有「呼吸感」？', author:'调色盘', avatar:'调', color:'#d4a634', cat:'design', tags:['hot'], replies:89, views:2100, time:'1 小时前', pinned:false },
    { id:5, title:'读完《百年孤独》的一些碎片感受', author:'书虫阿九', avatar:'书', color:'#9b7ec9', cat:'reading', tags:['new'], replies:31, views:542, time:'2 小时前', pinned:false },
    { id:6, title:'一段短片：暴雨后的城市倒影', author:'镜头诗人', avatar:'镜', color:'#c9895d', cat:'creative', tags:[], replies:24, views:410, time:'3 小时前', pinned:false },
    { id:7, title:'建议增加帖子收藏夹功能', author:'小透明', avatar:'小', color:'#5dc9b8', cat:'feedback', tags:['new'], replies:16, views:320, time:'3 小时前', pinned:false },
    { id:8, title:'从零开始搭建一个个人知识管理系统', author:'思维导图', avatar:'思', color:'#5d8ec9', cat:'tech', tags:[], replies:52, views:1560, time:'4 小时前', pinned:false },
  ];

  const threadReplies = {
    1: [
      { author:'深海鱼', avatar:'深', color:'#5d8ec9', time:'10 分钟前', text:'我认为 Python 依然是入门和数据领域的首选，但 Rust 和 Go 在系统级和云原生方面的势头非常强劲。TypeScript 也已经是前端的事实标准了。大家怎么看？' },
      { author:'代码搬运工', avatar:'代', color:'#d4a634', time:'25 分钟前', text:'推荐 Rust。学曲线虽陡，但一旦上手后写代码的自信感完全不同。编译器帮你抓 bug，这种安全感是其他语言给不了的。' },
      { author:'前端小王子', avatar:'前', color:'#c95d5d', time:'38 分钟前', text:'TypeScript + 1。现在后端也有 Deno 和 Bun，TypeScript 的全栈能力越来越强了。' },
      { author:'算法苦手', avatar:'算', color:'#9b7ec9', time:'1 小时前', text:'如果目标是找工作的话，Java 和 Python 依然是最稳的选择。不过如果追求技术深度，Rust 确实值得投入。' },
      { author:'深夜码农', avatar:'深', color:'#5cb87a', time:'2 小时前', text:'别忘了 Zig，虽然小众但在底层开发圈子里越来越受欢迎了。' },
    ],
    2: [
      { author:'铁锈猎人', avatar:'铁', color:'#c95d5d', time:'32 分钟前', text:'原来用 Python 写的数据处理管道跑一次要 12 分钟，用 Rust 重写后只要 18 秒。主要是零拷贝解析和 SIMD 加速带来的提升。' },
      { author:'性能狂魔', avatar:'性', color:'#d4a634', time:'45 分钟前', text:'太强了，可以分享一下 GitHub 仓库吗？想学习一下你的解析策略。' },
    ],
    3: [
      { author:'木白', avatar:'木', color:'#7ac9a8', time:'1 小时前', text:'最近把桌面清理到只剩显示器、键盘和一杯水。感觉专注力提升了不止一个档次。less is more。' },
    ],
  };

  const activeUsers = [
    { name:'深海鱼', role:'版主 · 技术讨论', avatar:'深', color:'#5d8ec9' },
    { name:'调色盘', role:'活跃会员', avatar:'调', color:'#d4a634' },
    { name:'书虫阿九', role:'读书会版主', avatar:'书', color:'#9b7ec9' },
    { name:'铁锈猎人', role:'活跃会员', avatar:'铁', color:'#c95d5d' },
    { name:'镜头诗人', role:'创作达人', avatar:'镜', color:'#c9895d' },
  ];

  const trending = [
    { num:'#1', title:'Rust 重写 CLI 工具性能提升 40x', meta:'128 回复 · 3.4k 浏览' },
    { num:'#2', title:'2026 最值得学的编程语言', meta:'89 回复 · 2.1k 浏览' },
    { num:'#3', title:'极简工作台布置分享', meta:'43 回复 · 876 浏览' },
    { num:'#4', title:'配色方案的呼吸感', meta:'67 回复 · 1.8k 浏览' },
    { num:'#5', title:'个人知识管理系统搭建', meta:'52 回复 · 1.5k 浏览' },
  ];

  // ─── Render Threads ───
  function renderThreads() {
    const list = document.getElementById('threadList');
    list.innerHTML = threads.map(t => `
      <div class="thread-item ${t.pinned ? 'pinned' : ''}" data-id="${t.id}">
        <div class="thread-avatar" style="background:${t.color}">${t.avatar}</div>
        <div class="thread-body">
          <div class="thread-tags">
            ${t.pinned ? '<span class="tag pin">置顶</span>' : ''}
            ${t.tags.map(tag => `<span class="tag ${tag}">${tag === 'hot' ? '热' : '新'}</span>`).join('')}
          </div>
          <div class="thread-title">${t.title}</div>
          <div class="thread-meta">
            <span class="author">${t.author}</span>
            <span>·</span>
            <span>${t.time}</span>
            <span>·</span>
            <span>${t.views} 浏览</span>
          </div>
        </div>
        <div class="thread-stats-col">
          <div class="reply-count"><span class="num">${t.replies}</span> 回复</div>
          <div class="last-reply">${t.time}</div>
        </div>
      </div>
    `).join('');

    // Click handlers
    list.querySelectorAll('.thread-item').forEach(el => {
      el.addEventListener('click', () => openThread(+el.dataset.id));
    });
  }

  // ─── Render Sidebar ───
  function renderSidebar() {
    const usersEl = document.getElementById('activeUsers');
    usersEl.innerHTML = activeUsers.map(u => `
      <div class="user-row">
        <div class="user-mini-avatar" style="background:${u.color}">${u.avatar}</div>
        <div class="user-info">
          <div class="user-name">${u.name}</div>
          <div class="user-role">${u.role}</div>
        </div>
      </div>
    `).join('');

    const trendingEl = document.getElementById('trendingTopics');
    trendingEl.innerHTML = trending.map(t => `
      <div class="trending-item">
        <div class="trending-num">${t.num}</div>
        <div class="trending-title">${t.title}</div>
        <div class="trending-meta">${t.meta}</div>
      </div>
    `).join('');
  }

  // ─── Open Thread Detail ───
  function openThread(id) {
    const thread = threads.find(t => t.id === id);
    if (!thread) return;

    document.getElementById('modalTitle').textContent = thread.title;

    const replies = threadReplies[id] || [
      { author: thread.author, avatar: thread.avatar, color: thread.color, time: thread.time, text: '帖子内容加载中…（测试数据）' }
    ];

    const body = document.getElementById('modalBody');
    body.innerHTML = replies.map(r => `
      <div class="post">
        <div class="post-avatar" style="background:${r.color}">${r.avatar}</div>
        <div class="post-content">
          <div class="post-header">
            <span class="post-author">${r.author}</span>
            <span class="post-time">${r.time}</span>
          </div>
          <div class="post-text">${r.text}</div>
          <div class="post-actions">
            <button class="post-action">&#9825; 赞同</button>
            <button class="post-action">&#8634; 回复</button>
            <button class="post-action">&#8943; 更多</button>
          </div>
        </div>
      </div>
    `).join('');

    document.getElementById('threadModal').classList.add('open');
    document.getElementById('replyInput').value = '';
  }

  // ─── Submit Reply ───
  document.getElementById('submitReply').addEventListener('click', () => {
    const input = document.getElementById('replyInput');
    const text = input.value.trim();
    if (!text) return;

    const body = document.getElementById('modalBody');
    const newPost = document.createElement('div');
    newPost.className = 'post';
    newPost.innerHTML = `
      <div class="post-avatar" style="background:#5dc9b8">我</div>
      <div class="post-content">
        <div class="post-header">
          <span class="post-author">当前用户</span>
          <span class="post-time">刚刚</span>
        </div>
        <div class="post-text">${text.replace(/</g,'&lt;').replace(/>/g,'&gt;')}</div>
        <div class="post-actions">
          <button class="post-action">&#9825; 赞同</button>
          <button class="post-action">&#8634; 回复</button>
          <button class="post-action">&#8943; 更多</button>
        </div>
      </div>
    `;
    body.appendChild(newPost);
    input.value = '';
    body.scrollTop = body.scrollHeight;
  });

  // ─── New Thread ───
  document.getElementById('newThreadBtn').addEventListener('click', () => {
    document.getElementById('newThreadModal').classList.add('open');
  });

  document.getElementById('submitThread').addEventListener('click', () => {
    const title = document.getElementById('newTitle').value.trim();
    const content = document.getElementById('newContent').value.trim();
    if (!title) return;

    const colors = avatarColors;
    const color = colors[Math.floor(Math.random() * colors.length)];

    threads.unshift({
      id: threads.length + 1,
      title: title,
      author: '当前用户',
      avatar: '我',
      color: '#5dc9b8',
      cat: document.getElementById('newCategory').value || 'life',
      tags: ['new'],
      replies: 0,
      views: 1,
      time: '刚刚',
      pinned: false,
    });

    if (content) {
      threadReplies[threads[0].id] = [
        { author:'当前用户', avatar:'我', color:'#5dc9b8', time:'刚刚', text: content }
      ];
    }

    renderThreads();
    document.getElementById('newThreadModal').classList.remove('open');
    document.getElementById('newTitle').value = '';
    document.getElementById('newContent').value = '';
    document.getElementById('newCategory').selectedIndex = 0;
  });

  // ─── Close Modals ───
  document.getElementById('modalClose').addEventListener('click', () => {
    document.getElementById('threadModal').classList.remove('open');
  });

  document.getElementById('threadModal').addEventListener('click', (e) => {
    if (e.target === e.currentTarget) e.currentTarget.classList.remove('open');
  });

  document.getElementById('newThreadModal').addEventListener('click', (e) => {
    if (e.target === e.currentTarget) e.currentTarget.classList.remove('open');
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.getElementById('threadModal').classList.remove('open');
      document.getElementById('newThreadModal').classList.remove('open');
    }
  });

  // ─── Login Mock ───
  document.getElementById('loginBtn').addEventListener('click', () => {
    const btn = document.getElementById('loginBtn');
    if (btn.textContent === '登录') {
      btn.textContent = '当前用户';
      btn.style.borderColor = 'var(--green)';
      btn.style.color = 'var(--green)';
    } else {
      btn.textContent = '登录';
      btn.style.borderColor = '';
      btn.style.color = '';
    }
  });

  // ─── Nav ───
  document.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', () => {
      document.querySelectorAll('.nav-link').forEach(l => l.classList.remove('active'));
      link.classList.add('active');
    });
  });

  // ─── Online count fluctuation ───
  setInterval(() => {
    const el = document.getElementById('onlineCount');
    const current = parseInt(el.textContent);
    const delta = Math.floor(Math.random() * 5) - 2;
    el.textContent = Math.max(300, current + delta);
  }, 5000);

  // ─── Init ───
  renderThreads();
  renderSidebar();
</script>
</body>
</html>
